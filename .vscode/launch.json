{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Run Server",
        "command": "npx http-server -p 8080 -c-1",
        "request": "launch",
        "type": "node-terminal"
      },
      {
        "name": "Launch Chrome",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}"
      }
    ],
    "compounds": [
      {
        "name": "Launch App",
        "configurations": ["Run Server", "Launch Chrome"]
      }
    ]
  }